{
  "name": "pi-minimodel-ocr",
  "version": "0.3.1",
  "description": "Pi extension: Multi-backend OCR — Ollama (local GPU), MinerU (free cloud API), PaddleOCR (local Python). Extracts text, LaTeX formulas, and tables from images and PDFs. Bridges the multimodal gap for non-vision LLMs like DeepSeek.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "coding-agent",
    "ocr",
    "glm-ocr",
    "ollama",
    "mineru",
    "paddleocr",
    "latex",
    "math-ocr",
    "formula-recognition",
    "image-to-text",
    "pdf-to-markdown",
    "deepseek",
    "multi-backend"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/astronautJack/pi-minimodel-ocr.git"
  },
  "files": [
    "extensions/",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@types/node": "^25.9.1",
    "typebox": "*",
    "typescript": "^6.0.3"
  }
}
